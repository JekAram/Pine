//@version=6
indicator("XAUUSD Fib · FRVP · OB", shorttitle="XAU·FOB", overlay=true, max_lines_count=200, max_labels_count=200, max_boxes_count=50)

// ═══════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════
grp1 = "📐 Fibonacci"
fib_len       = input.int(10,   "Swing Length",          minval=3, maxval=50, group=grp1)
show_fib      = input.bool(true, "Show Fibonacci",        group=grp1)

grp2 = "📊 Volume Profile"
vp_lookback   = input.int(50,   "FRVP Lookback (bars)",  minval=10, maxval=200, group=grp2)
vp_buckets    = input.int(20,   "FRVP Buckets",          minval=10, maxval=40,  group=grp2)
show_vp       = input.bool(true, "Show Volume Profile",   group=grp2)

grp3 = "🟦 Order Block"
ob_atr_mult   = input.float(2.0, "Impulse Threshold (×ATR)", minval=1.0, maxval=5.0, step=0.5, group=grp3)
ob_max        = input.int(3,    "Max OB Displayed",      minval=1, maxval=5, group=grp3)
show_ob       = input.bool(true, "Show Order Blocks",     group=grp3)

grp4 = "📱 Dashboard"
show_dash     = input.bool(true, "Show Dashboard",        group=grp4)

// ═══════════════════════════════════════════════
// SWING DETECTION
// ═══════════════════════════════════════════════
swing_hi = ta.pivothigh(high, fib_len, fib_len)
swing_lo = ta.pivotlow(low,   fib_len, fib_len)

var float sh1 = na
var float sl1 = na
var int   sh1_bar = 0
var int   sl1_bar = 0

if not na(swing_hi)
    sh1     := swing_hi
    sh1_bar := bar_index[fib_len]

if not na(swing_lo)
    sl1     := swing_lo
    sl1_bar := bar_index[fib_len]

// ═══════════════════════════════════════════════
// STRUCTURE BIAS (simple: last swing direction)
// ═══════════════════════════════════════════════
bias_bull = not na(sl1) and not na(sh1) and sh1_bar > sl1_bar
bias_bear = not na(sl1) and not na(sh1) and sl1_bar > sh1_bar

// ═══════════════════════════════════════════════
// FIBONACCI RETRACEMENT
// ═══════════════════════════════════════════════
var line fib_382 = na
var line fib_500 = na
var line fib_618 = na
var label lbl_382 = na
var label lbl_500 = na
var label lbl_618 = na
var label lbl_0   = na
var label lbl_1   = na

f_price(fib_from, fib_to, lvl) =>
    fib_from + (fib_to - fib_from) * lvl

if show_fib and barstate.islast and not na(sh1) and not na(sl1)
    line.delete(fib_382)
    line.delete(fib_500)
    line.delete(fib_618)
    label.delete(lbl_382)
    label.delete(lbl_500)
    label.delete(lbl_618)
    label.delete(lbl_0)
    label.delete(lbl_1)

    float fib_from = bias_bull ? sl1 : sh1
    float fib_to   = bias_bull ? sh1 : sl1
    float p382 = f_price(fib_from, fib_to, 0.382)
    float p500 = f_price(fib_from, fib_to, 0.500)
    float p618 = f_price(fib_from, fib_to, 0.618)

    int x1 = bias_bull ? sl1_bar : sh1_bar
    int x2 = bar_index + 8

    fib_382 := line.new(x1, p382, x2, p382, color=color.new(color.orange, 30), style=line.style_dashed, width=1)
    fib_500 := line.new(x1, p500, x2, p500, color=color.new(color.yellow, 30), style=line.style_dashed, width=1)
    fib_618 := line.new(x1, p618, x2, p618, color=color.new(color.lime,   20), style=line.style_solid,  width=2)

    lbl_382 := label.new(x2 + 1, p382, "0.382  " + str.tostring(math.round(p382, 1)), color=color.new(color.orange, 70), textcolor=color.orange, style=label.style_label_left, size=size.small)
    lbl_500 := label.new(x2 + 1, p500, "0.500  " + str.tostring(math.round(p500, 1)), color=color.new(color.yellow, 70), textcolor=color.yellow, style=label.style_label_left, size=size.small)
    lbl_618 := label.new(x2 + 1, p618, "0.618  " + str.tostring(math.round(p618, 1)), color=color.new(color.lime,   60), textcolor=color.lime,   style=label.style_label_left, size=size.small)
    lbl_0   := label.new(x2 + 1, fib_from, "0.0    " + str.tostring(math.round(fib_from, 1)), color=color.new(color.gray, 70), textcolor=color.gray, style=label.style_label_left, size=size.small)
    lbl_1   := label.new(x2 + 1, fib_to,   "1.0    " + str.tostring(math.round(fib_to,   1)), color=color.new(color.gray, 70), textcolor=color.gray, style=label.style_label_left, size=size.small)

// ═══════════════════════════════════════════════
// FIXED RANGE VOLUME PROFILE
// ═══════════════════════════════════════════════
float vp_high = ta.highest(high, vp_lookback)
float vp_low  = ta.lowest(low,   vp_lookback)
float vp_step = (vp_high - vp_low) / vp_buckets

var float[] vol_bull = array.new_float(0)
var float[] vol_bear = array.new_float(0)
var float   poc_price = na
var float   vah_price = na
var float   val_price = na

var box[]  vp_boxes = array.new_box(0)
var line   poc_line = na
var line   vah_line = na
var line   val_line = na

if show_vp and barstate.islast
    // clear old boxes
    int box_cnt = array.size(vp_boxes)
    int i_clr = 0
    while i_clr < box_cnt
        box.delete(array.get(vp_boxes, i_clr))
        i_clr += 1
    array.clear(vp_boxes)
    line.delete(poc_line)
    line.delete(vah_line)
    line.delete(val_line)

    // init bucket arrays
    array.clear(vol_bull)
    array.clear(vol_bear)
    int b = 0
    while b < vp_buckets
        array.push(vol_bull, 0.0)
        array.push(vol_bear, 0.0)
        b += 1

    // fill buckets
    int n = 0
    while n < vp_lookback
        float bar_mid = (high[n] + low[n]) / 2.0
        int bucket = int(math.floor((bar_mid - vp_low) / vp_step))
        bucket := math.max(0, math.min(vp_buckets - 1, bucket))
        float bar_vol = volume[n] / 2.0
        bool is_bull_bar = close[n] >= open[n]
        float cur_bull = array.get(vol_bull, bucket)
        float cur_bear = array.get(vol_bear, bucket)
        if is_bull_bar
            array.set(vol_bull, bucket, cur_bull + bar_vol)
        else
            array.set(vol_bear, bucket, cur_bear + bar_vol)
        n += 1

    // find POC
    float max_vol = 0.0
    int   poc_idx = 0
    int   k = 0
    while k < vp_buckets
        float tv = array.get(vol_bull, k) + array.get(vol_bear, k)
        if tv > max_vol
            max_vol := tv
            poc_idx := k
        k += 1

    // total volume for Value Area (70%)
    float total_vol = 0.0
    int kk = 0
    while kk < vp_buckets
        total_vol += array.get(vol_bull, kk) + array.get(vol_bear, kk)
        kk += 1
    float va_target = total_vol * 0.7
    float va_accum  = array.get(vol_bull, poc_idx) + array.get(vol_bear, poc_idx)
    int   va_lo_idx = poc_idx
    int   va_hi_idx = poc_idx

    while va_accum < va_target
        float add_hi = va_hi_idx + 1 < vp_buckets ? array.get(vol_bull, va_hi_idx + 1) + array.get(vol_bear, va_hi_idx + 1) : 0.0
        float add_lo = va_lo_idx - 1 >= 0         ? array.get(vol_bull, va_lo_idx - 1) + array.get(vol_bear, va_lo_idx - 1) : 0.0
        if add_hi >= add_lo and va_hi_idx + 1 < vp_buckets
            va_hi_idx += 1
            va_accum  += add_hi
        else if va_lo_idx - 1 >= 0
            va_lo_idx -= 1
            va_accum  += add_lo
        else
            break

    poc_price := vp_low + (poc_idx + 0.5) * vp_step
    vah_price := vp_low + (va_hi_idx + 1) * vp_step
    val_price := vp_low + va_lo_idx * vp_step

    // max vol for bar width scaling
    float max_bvol = 0.0
    int mvi = 0
    while mvi < vp_buckets
        float tv2 = array.get(vol_bull, mvi) + array.get(vol_bear, mvi)
        if tv2 > max_bvol
            max_bvol := tv2
        mvi += 1

    // draw histogram boxes
    int bar_w = 12
    int p = 0
    while p < vp_buckets
        float bvol  = array.get(vol_bull, p) + array.get(vol_bear, p)
        float bfrac = max_bvol > 0.0 ? bvol / max_bvol : 0.0
        int   blen  = int(math.round(bfrac * bar_w))
        blen := math.max(1, blen)

        float b_lo = vp_low + p * vp_step
        float b_hi = b_lo + vp_step * 0.85

        bool in_va = p >= va_lo_idx and p <= va_hi_idx
        bool is_poc_bar = p == poc_idx

        color bc = is_poc_bar ? color.new(color.orange, 30) : in_va ? color.new(color.teal, 60) : color.new(color.gray, 75)

        box bx = box.new(bar_index + 1, b_hi, bar_index + 1 + blen, b_lo, border_color=color.new(color.gray, 90), bgcolor=bc)
        array.push(vp_boxes, bx)
        p += 1

    // POC / VAH / VAL lines
    poc_line := line.new(bar_index - vp_lookback, poc_price, bar_index + bar_w + 2, poc_price, color=color.new(color.orange, 0), style=line.style_solid, width=2)
    vah_line := line.new(bar_index - vp_lookback, vah_price, bar_index + bar_w + 2, vah_price, color=color.new(color.teal, 30),   style=line.style_dashed, width=1)
    val_line := line.new(bar_index - vp_lookback, val_price, bar_index + bar_w + 2, val_price, color=color.new(color.teal, 30),   style=line.style_dashed, width=1)

    label.new(bar_index + bar_w + 3, poc_price, "POC " + str.tostring(math.round(poc_price, 1)), color=color.new(color.orange, 60), textcolor=color.orange, style=label.style_label_left, size=size.small)
    label.new(bar_index + bar_w + 3, vah_price, "VAH " + str.tostring(math.round(vah_price, 1)), color=color.new(color.teal, 70),   textcolor=color.teal,   style=label.style_label_left, size=size.small)
    label.new(bar_index + bar_w + 3, val_price, "VAL " + str.tostring(math.round(val_price, 1)), color=color.new(color.teal, 70),   textcolor=color.teal,   style=label.style_label_left, size=size.small)

// ═══════════════════════════════════════════════
// ORDER BLOCK DETECTION
// ═══════════════════════════════════════════════
float atr14 = ta.atr(14)

is_impulse_up   = (close - open) > ob_atr_mult * atr14
is_impulse_down = (open - close) > ob_atr_mult * atr14

// Bullish OB: last bearish candle before impulse up
bull_ob_bar = is_impulse_up and close[1] < open[1]
// Bearish OB: last bullish candle before impulse down
bear_ob_bar = is_impulse_down and close[1] > open[1]

var box[]   ob_box_list  = array.new_box(0)
var bool[]  ob_is_bull   = array.new_bool(0)
var float[] ob_hi_list   = array.new_float(0)
var float[] ob_lo_list   = array.new_float(0)

// add new OB
if show_ob
    if bull_ob_bar
        float ob_hi = math.max(open[1], close[1])
        float ob_lo = math.min(open[1], close[1])
        box nb = box.new(bar_index - 1, ob_hi, bar_index + 40, ob_lo, border_color=color.new(color.green, 40), bgcolor=color.new(color.green, 82))
        label.new(bar_index, ob_hi, "OB↑", color=color.new(color.green, 50), textcolor=color.white, style=label.style_label_down, size=size.small)
        array.unshift(ob_box_list, nb)
        array.unshift(ob_is_bull,  true)
        array.unshift(ob_hi_list,  ob_hi)
        array.unshift(ob_lo_list,  ob_lo)

    if bear_ob_bar
        float ob_hi = math.max(open[1], close[1])
        float ob_lo = math.min(open[1], close[1])
        box nb = box.new(bar_index - 1, ob_hi, bar_index + 40, ob_lo, border_color=color.new(color.red, 40), bgcolor=color.new(color.red, 82))
        label.new(bar_index, ob_lo, "OB↓", color=color.new(color.red, 50), textcolor=color.white, style=label.style_label_up, size=size.small)
        array.unshift(ob_box_list, nb)
        array.unshift(ob_is_bull,  false)
        array.unshift(ob_hi_list,  ob_hi)
        array.unshift(ob_lo_list,  ob_lo)

// mitigate OB when price closes through it
if show_ob and array.size(ob_box_list) > 0
    int oi = 0
    while oi < array.size(ob_box_list)
        bool is_b = array.get(ob_is_bull, oi)
        float ohi = array.get(ob_hi_list, oi)
        float olo = array.get(ob_lo_list, oi)
        bool mitigated = is_b ? close < olo : close > ohi
        if mitigated
            box.delete(array.get(ob_box_list, oi))
            array.remove(ob_box_list, oi)
            array.remove(ob_is_bull,  oi)
            array.remove(ob_hi_list,  oi)
            array.remove(ob_lo_list,  oi)
        else
            oi += 1

// keep only ob_max most recent
while array.size(ob_box_list) > ob_max
    int last = array.size(ob_box_list) - 1
    box.delete(array.get(ob_box_list, last))
    array.pop(ob_box_list)
    array.pop(ob_is_bull)
    array.pop(ob_hi_list)
    array.pop(ob_lo_list)

// ═══════════════════════════════════════════════
// DASHBOARD  — iPhone optimised
// ═══════════════════════════════════════════════
if show_dash and barstate.islast
    var table d = table.new(position.bottom_left, 2, 6, bgcolor=color.new(color.black, 15), border_color=color.new(color.gray, 40), border_width=1, frame_color=color.new(color.gray, 20), frame_width=1)

    // header
    string tf_mode = timeframe.in_seconds() / 60 <= 1 ? "SCALP" : timeframe.in_seconds() / 60 <= 15 ? "ENTRY" : timeframe.in_seconds() / 60 <= 60 ? "SWING" : "BIAS"
    table.cell(d, 0, 0, "⬡ XAUUSD  " + tf_mode, text_color=color.white, text_size=size.normal, bgcolor=color.new(color.navy, 20), text_halign=text.align_left)
    table.cell(d, 1, 0, timeframe.period + "M",  text_color=color.silver, text_size=size.normal, bgcolor=color.new(color.navy, 20), text_halign=text.align_center)

    // bias
    string bias_str = bias_bull ? "▲ Bullish" : bias_bear ? "▼ Bearish" : "── Neutral"
    color  bias_col = bias_bull ? color.lime   : bias_bear ? color.red   : color.gray
    table.cell(d, 0, 1, "Bias",     text_color=color.silver, text_size=size.small, text_halign=text.align_left)
    table.cell(d, 1, 1, bias_str,   text_color=bias_col,     text_size=size.small, text_halign=text.align_center)

    // fib zone
    float cur_p382 = not na(sh1) and not na(sl1) ? f_price(bias_bull ? sl1 : sh1, bias_bull ? sh1 : sl1, 0.382) : na
    float cur_p618 = not na(sh1) and not na(sl1) ? f_price(bias_bull ? sl1 : sh1, bias_bull ? sh1 : sl1, 0.618) : na
    bool  near_618 = not na(cur_p618) and math.abs(close - cur_p618) < atr14 * 1.0
    bool  near_382 = not na(cur_p382) and math.abs(close - cur_p382) < atr14 * 1.0
    string fib_str = near_618 ? "⭐ 0.618 Golden" : near_382 ? "0.382 Zone" : "──"
    color  fib_col = near_618 ? color.lime : near_382 ? color.orange : color.gray
    table.cell(d, 0, 2, "Fib Zone",  text_color=color.silver, text_size=size.small, text_halign=text.align_left)
    table.cell(d, 1, 2, fib_str,     text_color=fib_col,      text_size=size.small, text_halign=text.align_center)

    // POC proximity
    bool  near_poc = not na(poc_price) and math.abs(close - poc_price) < atr14 * 1.0
    bool  above_vah = not na(vah_price) and close > vah_price
    bool  below_val = not na(val_price) and close < val_price
    string poc_str = near_poc ? "@ POC " + str.tostring(math.round(poc_price, 1)) : above_vah ? "Above VAH" : below_val ? "Below VAL" : "In VA"
    color  poc_col = near_poc ? color.orange : above_vah ? color.lime : below_val ? color.red : color.gray
    table.cell(d, 0, 3, "FRVP",     text_color=color.silver, text_size=size.small, text_halign=text.align_left)
    table.cell(d, 1, 3, poc_str,    text_color=poc_col,      text_size=size.small, text_halign=text.align_center)

    // OB count
    int   ob_cnt = array.size(ob_box_list)
    string ob_str = ob_cnt > 0 ? str.tostring(ob_cnt) + " Active OB" : "No OB"
    color  ob_col = ob_cnt > 0 ? color.aqua : color.gray
    table.cell(d, 0, 4, "OB",       text_color=color.silver, text_size=size.small, text_halign=text.align_left)
    table.cell(d, 1, 4, ob_str,     text_color=ob_col,       text_size=size.small, text_halign=text.align_center)

    // confluence signal
    bool conf_buy  = bias_bull and (near_618 or near_382) and ob_cnt > 0
    bool conf_sell = bias_bear and (near_618 or near_382) and ob_cnt > 0
    string sig_str  = conf_buy ? "◆ BUY Conf" : conf_sell ? "◆ SELL Conf" : "── WAIT"
    color  sig_col  = conf_buy ? color.lime : conf_sell ? color.red : color.gray
    color  sig_bg   = conf_buy ? color.new(color.green, 65) : conf_sell ? color.new(color.red, 65) : color.new(color.black, 30)
    table.cell(d, 0, 5, "Signal",   text_color=color.silver, text_size=size.small,  text_halign=text.align_left)
    table.cell(d, 1, 5, sig_str,    text_color=sig_col,      text_size=size.large,  bgcolor=sig_bg, text_halign=text.align_center)

// ═══════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════
float cp382 = not na(sh1) and not na(sl1) ? f_price(bias_bull ? sl1 : sh1, bias_bull ? sh1 : sl1, 0.382) : na
float cp618 = not na(sh1) and not na(sl1) ? f_price(bias_bull ? sl1 : sh1, bias_bull ? sh1 : sl1, 0.618) : na
bool a_near618 = not na(cp618) and math.abs(close - cp618) < atr14 * 1.0
bool a_near382 = not na(cp382) and math.abs(close - cp382) < atr14 * 1.0
bool a_conf_buy  = bias_bull and (a_near618 or a_near382) and array.size(ob_box_list) > 0 and barstate.isconfirmed
bool a_conf_sell = bias_bear and (a_near618 or a_near382) and array.size(ob_box_list) > 0 and barstate.isconfirmed

if a_conf_buy
    alert("◆ XAU BUY Confluence | Fib + OB | " + str.tostring(close), alert.freq_once_per_bar_close)
if a_conf_sell
    alert("◆ XAU SELL Confluence | Fib + OB | " + str.tostring(close), alert.freq_once_per_bar_close)
